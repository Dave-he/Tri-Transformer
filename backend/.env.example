DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/tritransformer
SECRET_KEY=your-secret-key-change-in-production-must-be-long-enough
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
MOCK_INFERENCE=true
MODEL_PATH=/path/to/tri-transformer/weights
EMBEDDING_MODEL_PATH=BAAI/bge-large-zh-v1.5
RERANKER_MODEL_PATH=BAAI/bge-reranker-large
CHROMA_PERSIST_DIR=./chroma_db
CHUNK_SIZE=512
CHUNK_OVERLAP=50
TOP_K_RETRIEVAL=10
TOP_K_RERANK=5
